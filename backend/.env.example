DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cloud_chat"
REDIS_URL="redis://localhost:6379"

JWT_ACCESS_SECRET="your-access-secret-min-32-chars-here"
JWT_REFRESH_SECRET="your-refresh-secret-min-32-chars-here"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"

CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_FROM="noreply@cloud-chat.app"

FRONTEND_URL="http://localhost:3000"
PORT=4000
NODE_ENV="development"



